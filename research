<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Designing Trust for Human-Agent Teaming · Navyaa Vemuri</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍊</text></svg>">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #FDFDFD;
      --surface: #F4F3F0;
      --surface-2: #F8F7F4;
      --border: #E8E8E4;
      --text: #1A1A1A;
      --muted: #6B6B6B;
      --dim: #ABABAB;
      --accent: #2E5B4E;
      --accent-soft: #ECF4F0;
      --accent-border: #D3E2DB;
      --gold: #B78A2D;
      --gold-soft: #FAF5E8;
      --gold-border: #E8DAB5;
      --nav-w: 284px;
      --hero-h: 560px;
      --shadow: 0 8px 30px rgba(30, 40, 35, 0.05);
      --radius: 12px;
    }

    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    .layout {
      display: flex;
      min-height: 100vh;
    }

    .cs-sidebar {
      width: var(--nav-w);
      flex-shrink: 0;
      position: sticky;
      top: 0;
      height: 100vh;
      padding: 48px 40px;
      display: flex;
      flex-direction: column;
      border-right: .5px solid var(--border);
      overflow-y: auto;
      scrollbar-width: none;
      background: rgba(253,253,253,.92);
      backdrop-filter: blur(8px);
    }

    .cs-sidebar::-webkit-scrollbar { display: none; }

    .stamp {
      width: 156px;
      margin-bottom: 30px;
      flex-shrink: 0;
    }

    .stamp img {
      width: 100%;
      display: block;
      min-height: 130px;
      background: #E8EAF0;
      border-radius: 4px;
      animation: stampFloat 4s ease-in-out infinite;
      will-change: transform;
    }

    .stamp:hover img { animation-play-state: paused; }

    @keyframes stampFloat {
      0% { transform: translateY(0) rotate(-.5deg); }
      33% { transform: translateY(-6px) rotate(.3deg); }
      66% { transform: translateY(-3px) rotate(-.2deg); }
      100% { transform: translateY(0) rotate(-.5deg); }
    }

    .toc-label {
      font-size: 9px;
      color: var(--dim);
      letter-spacing: .16em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }

    .toc-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1px;
      margin-bottom: auto;
    }

    .toc-link {
      font-size: 13px;
      color: var(--dim);
      text-decoration: none;
      display: block;
      padding: 6px 0 6px 12px;
      border-left: 1.5px solid var(--border);
      transition: color .2s, border-color .2s, padding-left .18s;
      line-height: 1.4;
    }

    .toc-link:hover {
      color: var(--text);
      border-left-color: #ABABAB;
      padding-left: 15px;
    }

    .toc-link.active {
      color: var(--accent);
      border-left-color: var(--accent);
      padding-left: 16px;
    }

    .back-link {
      font-size: 11px;
      color: var(--dim);
      text-decoration: none;
      letter-spacing: .06em;
      text-transform: uppercase;
      padding-top: 24px;
      border-top: .5px solid var(--border);
      margin-top: 24px;
      transition: color .2s;
      flex-shrink: 0;
    }

    .back-link:hover { color: var(--text); }

    .right-col {
      flex: 1;
      overflow-y: auto;
      min-width: 0;
    }

    .hero-media {
      width: 100%;
      min-height: var(--hero-h);
      max-height: var(--hero-h);
      position: relative;
      overflow: hidden;
      border-bottom: .5px solid var(--border);
      background:
        radial-gradient(circle at top left, rgba(183,138,45,.16), transparent 34%),
        radial-gradient(circle at bottom right, rgba(46,91,78,.16), transparent 40%),
        linear-gradient(135deg, #F7F4ED 0%, #F7F8F6 48%, #EFF5F1 100%);
    }

    .hero-grid {
      height: 100%;
      display: grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 28px;
      align-items: stretch;
      padding: 42px 64px;
    }

    .hero-copy,
    .hero-visual {
      border: .5px solid rgba(255,255,255,.5);
      background: rgba(255,255,255,.52);
      backdrop-filter: blur(6px);
      border-radius: 18px;
      box-shadow: var(--shadow);
    }

    .hero-copy {
      padding: 42px 40px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-kicker {
      font-size: 11px;
      color: var(--accent);
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }

    .hero-title {
      font-size: 52px;
      line-height: 1.03;
      letter-spacing: -.04em;
      font-weight: 300;
      max-width: 620px;
      margin-bottom: 18px;
    }

    .hero-title em {
      color: var(--accent);
      font-style: italic;
    }

    .hero-subtitle {
      font-size: 17px;
      line-height: 1.72;
      color: var(--muted);
      max-width: 610px;
      margin-bottom: 24px;
    }

    .hero-subtitle strong {
      color: var(--text);
      font-weight: 400;
    }

    .hero-note {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      width: fit-content;
      background: var(--accent-soft);
      border: .5px solid var(--accent-border);
      color: var(--accent);
      border-radius: 999px;
      padding: 8px 14px;
      font-size: 12px;
      margin-bottom: 28px;
    }

    .hero-meta {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border: .5px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      background: rgba(255,255,255,.7);
    }

    .hero-meta-cell {
      padding: 16px 18px;
    }

    .hero-meta-cell + .hero-meta-cell {
      border-left: .5px solid var(--border);
    }

    .hero-meta-label {
      font-size: 10px;
      color: var(--dim);
      letter-spacing: .1em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .hero-meta-value {
      font-size: 13px;
      line-height: 1.4;
      color: var(--text);
    }

    .hero-visual {
      padding: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .cycle-wrap {
      position: relative;
      width: 100%;
      max-width: 520px;
      aspect-ratio: 1 / 1;
    }

    .cycle-ring {
      position: absolute;
      inset: 12% 10%;
      border: 1.6px solid rgba(183,138,45,.75);
      border-radius: 50%;
    }

    .cycle-core {
      position: absolute;
      width: 180px;
      height: 180px;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      background: linear-gradient(145deg, #ffffff 0%, #F3F6F4 100%);
      border: .5px solid var(--border);
      box-shadow: var(--shadow);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 20px;
      font-size: 21px;
      line-height: 1.2;
      color: var(--accent);
      letter-spacing: -.02em;
      font-weight: 300;
    }

    .cycle-card {
      position: absolute;
      width: 190px;
      background: white;
      border: .5px solid var(--border);
      border-radius: 12px;
      padding: 18px 18px 16px;
      box-shadow: var(--shadow);
    }

    .cycle-card:nth-child(3) { top: 0; left: 50%; transform: translateX(-50%); }
    .cycle-card:nth-child(4) { right: 0; top: 50%; transform: translateY(-50%); }
    .cycle-card:nth-child(5) { bottom: 0; left: 50%; transform: translateX(-50%); }
    .cycle-card:nth-child(6) { left: 0; top: 50%; transform: translateY(-50%); }

    .cycle-step {
      font-size: 10px;
      color: var(--gold);
      letter-spacing: .14em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .cycle-title {
      font-size: 18px;
      line-height: 1.18;
      margin-bottom: 6px;
      letter-spacing: -.02em;
      color: var(--text);
      font-weight: 400;
    }

    .cycle-desc {
      font-size: 12px;
      line-height: 1.55;
      color: var(--muted);
    }

    .cs-main {
      padding: 52px 64px 96px;
      max-width: 980px;
    }

    .cs-section {
      margin-bottom: 72px;
      scroll-margin-top: 24px;
    }

    .cs-section-label {
      font-size: 11px;
      color: var(--dim);
      letter-spacing: .16em;
      text-transform: uppercase;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 500;
    }

    .cs-section-label::after {
      content: '';
      flex: 1;
      height: .5px;
      background: var(--border);
    }

    .cs-h2 {
      font-size: 31px;
      font-weight: 400;
      color: var(--text);
      letter-spacing: -.03em;
      line-height: 1.16;
      margin-bottom: 14px;
      max-width: 760px;
    }

    .cs-h2 em {
      color: var(--accent);
      font-style: italic;
    }

    .cs-p {
      font-size: 15px;
      color: var(--muted);
      line-height: 1.82;
      margin-bottom: 14px;
      max-width: 760px;
    }

    .cs-p strong {
      color: var(--text);
      font-weight: 400;
    }

    .callout {
      margin-top: 18px;
      background: var(--gold-soft);
      border: .5px solid var(--gold-border);
      border-radius: 12px;
      padding: 18px 20px;
      max-width: 760px;
    }

    .callout-label {
      font-size: 10px;
      color: var(--gold);
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .callout-body {
      font-size: 14px;
      line-height: 1.7;
      color: var(--muted);
    }

    .meta-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-top: 24px;
    }

    .meta-card {
      background: var(--surface);
      border: .5px solid var(--border);
      border-radius: 12px;
      padding: 22px 22px 20px;
    }

    .meta-stat {
      font-size: 30px;
      line-height: 1;
      color: var(--accent);
      letter-spacing: -.03em;
      font-weight: 300;
      margin-bottom: 10px;
    }

    .meta-title {
      font-size: 12px;
      color: var(--dim);
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .meta-desc {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.62;
    }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-top: 18px;
    }

    .col-card {
      background: var(--surface);
      border: .5px solid var(--border);
      border-radius: 12px;
      padding: 22px 22px 18px;
    }

    .col-label {
      font-size: 10px;
      color: var(--accent);
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .col-item {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.65;
      padding: 8px 0;
      border-bottom: .5px solid var(--border);
    }

    .col-item:last-child { border-bottom: none; }

    .insight-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-top: 24px;
    }

    .insight-card {
      background: linear-gradient(180deg, #FFFFFF 0%, #FAFAF8 100%);
      border: .5px solid var(--border);
      border-radius: 14px;
      padding: 24px 22px;
      box-shadow: var(--shadow);
    }

    .insight-num {
      font-size: 11px;
      color: var(--gold);
      letter-spacing: .14em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .insight-title {
      font-size: 20px;
      line-height: 1.24;
      letter-spacing: -.02em;
      margin-bottom: 10px;
      color: var(--text);
    }

    .insight-copy {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.7;
    }

    .framework-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-top: 24px;
    }

    .framework-card {
      background: var(--surface-2);
      border: .5px solid var(--border);
      border-radius: 14px;
      padding: 24px 24px 22px;
    }

    .framework-phase {
      font-size: 10px;
      color: var(--gold);
      letter-spacing: .13em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .framework-title {
      font-size: 24px;
      letter-spacing: -.02em;
      line-height: 1.15;
      color: var(--text);
      margin-bottom: 10px;
      font-weight: 400;
    }

    .framework-copy {
      font-size: 14px;
      line-height: 1.75;
      color: var(--muted);
      margin-bottom: 14px;
    }

    .framework-example {
      background: #fff;
      border: .5px solid var(--border);
      border-left: 2px solid var(--accent);
      border-radius: 0 10px 10px 0;
      padding: 14px 16px;
    }

    .framework-example-label {
      font-size: 10px;
      color: var(--accent);
      letter-spacing: .1em;
      text-transform: uppercase;
      margin-bottom: 7px;
    }

    .framework-example p {
      font-size: 13px;
      line-height: 1.68;
      color: var(--muted);
    }

    .carousel-shell {
      margin-top: 26px;
      position: relative;
    }

    .carousel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 14px;
    }

    .carousel-note {
      font-size: 12px;
      color: var(--dim);
      line-height: 1.55;
    }

    .carousel-controls {
      display: flex;
      gap: 8px;
      flex-shrink: 0;
    }

    .carousel-btn {
      border: .5px solid var(--border);
      background: white;
      color: var(--text);
      border-radius: 999px;
      width: 40px;
      height: 40px;
      cursor: pointer;
      transition: transform .18s, border-color .2s, background .2s;
      box-shadow: var(--shadow);
    }

    .carousel-btn:hover {
      transform: translateY(-1px);
      border-color: #CFCFC9;
      background: #FCFCFB;
    }

    .carousel-track {
      display: flex;
      gap: 14px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 8px;
      scrollbar-width: none;
    }

    .carousel-track::-webkit-scrollbar { display: none; }

    .app-card {
      flex: 0 0 min(720px, 86vw);
      scroll-snap-align: start;
      background: white;
      border: .5px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: var(--shadow);
    }

    .app-image {
      position: relative;
      aspect-ratio: 16 / 9;
      background: linear-gradient(135deg, #ECE9E2 0%, #F8F8F5 52%, #ECF3EF 100%);
      overflow: hidden;
    }

    .app-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 24px;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.6;
      letter-spacing: -.01em;
    }

    .placeholder em {
      color: var(--accent);
      font-style: italic;
    }

    .app-body {
      padding: 24px 24px 20px;
    }

    .app-kicker {
      font-size: 10px;
      color: var(--gold);
      letter-spacing: .14em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .app-title {
      font-size: 28px;
      letter-spacing: -.03em;
      line-height: 1.12;
      margin-bottom: 10px;
      font-weight: 400;
    }

    .app-copy {
      font-size: 14px;
      line-height: 1.75;
      color: var(--muted);
      margin-bottom: 18px;
      max-width: 640px;
    }

    .bullet-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px 20px;
      margin-top: 6px;
    }

    .bullet-item {
      display: grid;
      grid-template-columns: 16px 1fr;
      gap: 10px;
      align-items: start;
      font-size: 13px;
      line-height: 1.7;
      color: var(--muted);
    }

    .bullet-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      margin-top: 8px;
    }

    .reflection-card,
    .future-card {
      background: linear-gradient(180deg, #FFFFFF 0%, #FBFBF9 100%);
      border: .5px solid var(--border);
      border-radius: 16px;
      padding: 28px;
      box-shadow: var(--shadow);
    }

    .future-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 14px;
      margin-top: 22px;
    }

    .future-mini {
      background: var(--surface);
      border: .5px solid var(--border);
      border-radius: 12px;
      padding: 20px 20px 18px;
    }

    .future-mini-title {
      font-size: 11px;
      color: var(--accent);
      letter-spacing: .13em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .future-mini-item {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.65;
      padding: 6px 0;
      border-bottom: .5px solid var(--border);
    }

    .future-mini-item:last-child { border-bottom: none; }

    .footer {
      border-top: .5px solid var(--border);
      padding: 32px 64px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 20px;
    }

    .footer-left {
      font-size: 12px;
      color: var(--dim);
    }

    .footer-left em {
      font-style: italic;
      color: var(--muted);
    }

    .footer-note {
      font-size: 11px;
      color: var(--dim);
      margin-top: 5px;
    }

    .footer-links {
      display: flex;
      gap: 20px;
      align-items: center;
      flex-wrap: wrap;
    }

    .footer-link {
      font-size: 12px;
      color: var(--muted);
      text-decoration: none;
      transition: color .2s;
    }

    .footer-link:hover { color: var(--text); }

    .footer-cta {
      font-size: 12px;
      color: var(--accent);
      text-decoration: none;
      border: .5px solid var(--accent-border);
      border-radius: 999px;
      padding: 8px 16px;
      transition: background .2s;
    }

    .footer-cta:hover { background: var(--accent-soft); }

    @media (max-width: 1180px) {
      .hero-grid {
        grid-template-columns: 1fr;
        padding: 28px 28px 32px;
      }

      .hero-media {
        max-height: none;
        min-height: auto;
      }

      .hero-title { font-size: 44px; }
    }

    @media (max-width: 980px) {
      .layout { flex-direction: column; }

      .cs-sidebar {
        position: static;
        width: 100%;
        height: auto;
        border-right: none;
        border-bottom: .5px solid var(--border);
        padding: 24px;
        flex-direction: row;
        flex-wrap: wrap;
        align-items: center;
        gap: 20px;
      }

      .stamp {
        width: 88px;
        margin-bottom: 0;
      }

      .toc-list {
        flex-direction: row;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: 0;
      }

      .toc-link {
        border-left: none;
        border-bottom: 1.5px solid var(--border);
        padding: 6px 10px;
      }

      .toc-link.active { border-bottom-color: var(--accent); }
      .back-link { border-top: none; margin-top: 0; padding-top: 0; }

      .cs-main,
      .footer {
        padding-left: 24px;
        padding-right: 24px;
      }

      .hero-copy,
      .hero-visual { padding: 26px; }

      .hero-title { font-size: 38px; }
      .hero-meta,
      .meta-row,
      .insight-grid,
      .framework-grid,
      .future-grid,
      .two-col,
      .bullet-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 680px) {
      .hero-title { font-size: 31px; }
      .cs-h2 { font-size: 25px; }
      .hero-meta { grid-template-columns: 1fr 1fr; }
      .hero-meta-cell:nth-child(3),
      .hero-meta-cell:nth-child(4) { border-top: .5px solid var(--border); }
      .hero-meta-cell:nth-child(3) { border-left: none; }
      .cycle-card {
        position: static;
        width: 100%;
        transform: none !important;
        margin-bottom: 10px;
      }
      .cycle-wrap {
        aspect-ratio: auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .cycle-ring,
      .cycle-core {
        position: static;
        transform: none;
        width: 100%;
        height: auto;
        border-radius: 16px;
      }
      .cycle-ring { display: none; }
      .cycle-core {
        padding: 26px;
        margin-bottom: 6px;
      }
      .footer {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      * {
        animation: none !important;
        transition: none !important;
